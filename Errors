<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Profile Page</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            background: #f4f4f4;
            padding: 40px;
        }

        .card {
            background: white;
            padding: 20px;
            width: 350px;
            margin: auto;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        img {
            width: 200px;
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <div class="card">
        <!-- Make sure photo.jpg is in the same folder as this HTML file -->
        <img src="photo.jpg" alt="Richard">
        <h2>Richard</h2>
        <p>Email: optimalyoungforever@gmail.com</p>
    </div>
</body>
</html>
