# 1. Variable (storing the dictionary in a variable)
student = {
    "Name": "Moses",
    "Age": 30,
    "Course": "AI"
}

# 2. Data Types (show the data type of the variable)
print("Data type of student:", type(student))

# 3. Operators (use an operator with the Age value)
next_year_age = student["Age"] + 1
print("Age next year:", next_year_age)

# 4. Function (create a function to display student details)
def show_student_info(data):
    print("\nStudent Information:")
    print("Name:", data["Name"])
    print("Age:", data["Age"])
    print("Course:", data["Course"])

# Call the function
show_student_info(student)

# 5. Loop (loop through the dictionary)
print("\nLooping through student dictionary:")
for key, value in student.items():
    print(key, ":", value)
