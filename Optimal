<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Optimal | Personal Website</title>
    <style>
        :root {
            --primary: #00d4ff;
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        html { scroll-behavior: smooth; }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Navigation */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 10%;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--primary);
            letter-spacing: -1px;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 2rem;
        }

        nav ul li a {
            text-decoration: none;
            color: var(--text-main);
            font-size: 0.95rem;
            font-weight: 500;
            transition: var(--transition);
        }

        nav ul li a:hover { color: var(--primary); }

        /* Hero Section */
        .hero {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 85vh;
            padding: 0 10%;
            gap: 4rem;
        }

        .hero-content { flex: 1; }

        .hero-image-container {
            flex: 1;
            display: flex;
            justify-content: center;
        }

        .hero-image-container img {
            width: 350px;
            height: 350px;
            object-fit: cover;
            border-radius: 30px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 2px solid rgba(0, 212, 255, 0.2);
            transition: var(--transition);
        }

        .hero-image-container img:hover {
            transform: translateY(-10px) rotate(2deg);
            border-color: var(--primary);
        }

        .hero h2 {
            font-size: 3.5rem;
            line-height: 1.1;
            margin-bottom: 1.5rem;
        }

        .hero h2 span { color: var(--primary); }

        .hero p {
            font-size: 1.1rem;
            color: var(--text-dim);
            margin-bottom: 2rem;
            max-width: 500px;
        }

        /* Motivation Section */
        .motivation {
            background: var(--card-bg);
            padding: 80px 10%;
            text-align: center;
            border-radius: 40px;
            margin: 0 5% 80px 5%;
        }

        #quote-display {
            font-size: 1.5rem;
            font-style: italic;
            margin: 2rem 0;
            min-height: 80px;
            color: var(--text-main);
        }

        /* General Button Styling */
        .btn {
            padding: 0.8rem 2rem;
            background: var(--primary);
            color: #000;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            display: inline-block;
        }

        .btn:hover {
            background: #fff;
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(0, 212, 255, 0.3);
        }

        /* Contact Section */
        .contact {
            padding: 100px 10%;
            text-align: center;
        }

        .contact a {
            font-size: 1.5rem;
            color: var(--primary);
            text-decoration: none;
            border-bottom: 2px solid transparent;
            transition: var(--transition);
        }

        .contact a:hover { border-bottom: 2px solid var(--primary); }

        /* Footer */
        footer {
            padding: 3rem;
            text-align: center;
            background: #000;
            color: var(--text-dim);
            font-size: 0.9rem;
        }

        /* Responsive */
        @media (max-width: 968px) {
            .hero { flex-direction: column-reverse; text-align: center; padding-top: 40px; }
            .hero h2 { font-size: 2.5rem; }
            nav ul { display: none; }
        }
    </style>
</head>
<body>

<nav>
    <div class="logo">OPTIMAL</div>
    <ul>
        <li><a href="#">Home</a></li>
        <li><a href="#motivation">Motivation</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>
</nav>

<section class="hero">
    <div class="hero-content">
        <h2>Hi, I'm <span>Optimal</span></h2>
        <p>Harnessing creativity and code to build a better future. I focus on growth, positivity, and high-impact digital solutions.</p>
        <a href="#contact" class="btn">Let's Work Together</a>
    </div>
    <div class="hero-image-container">
        <img src="Richard.jpg" alt="Optimal Profile Image">
    </div>
</section>

<section id="motivation" class="motivation">
    <h3 style="color: var(--primary); text-transform: uppercase; letter-spacing: 2px;">Daily Insight</h3>
    <div id="quote-display">"Your future is created by what you do today, not tomorrow."</div>
    <button class="btn" onclick="fetchNewQuote()">Get Inspired</button>
</section>

<section id="about" style="padding: 100px 10%; text-align: center;">
    <h2 style="margin-bottom: 20px;">The Vision</h2>
    <p style="max-width: 700px; margin: 0 auto; color: var(--text-dim);">
        Optimal is more than just a name—it's a mindset. I am dedicated to refining my craft in web development and helping others achieve their digital goals through clean, effective design.
    </p>
</section>

<section id="contact" class="contact">
    <h2>Get In Touch</h2>
    <p style="margin-bottom: 20px; color: var(--text-dim);">Open for collaborations and inquiries.</p>
    <a href="mailto:optimalyoungforever@gmail.com">optimalyoungforever@gmail.com</a>
</section>

<footer>
    <p>&copy; 2026 Optimal | Designed for Excellence</p>
</footer>

<script>
    async function fetchNewQuote() {
        const quoteEl = document.getElementById('quote-display');
        quoteEl.style.opacity = '0.5';
        quoteEl.innerText = "Searching for wisdom...";

        try {
            // Using a high-reliability fallback approach for the API
            const response = await fetch('https://api.allorigins.win/get?url=' + encodeURIComponent('https://zenquotes.io/api/random'));
            const json = await response.json();
            const data = JSON.parse(json.contents);
            
            quoteEl.style.opacity = '1';
            quoteEl.innerHTML = `"${data[0].q}" <br> <span style="font-size: 1rem; color: #00d4ff;">— ${data[0].a}</span>`;
        } catch (error) {
            quoteEl.style.opacity = '1';
            quoteEl.innerText = "The best way to predict the future is to create it.";
        }
    }
</script>

</body>
</html>
