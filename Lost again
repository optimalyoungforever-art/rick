<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>404 - Page Not Found</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}
body{
    height:100vh;
    background:linear-gradient(135deg,#0f172a,#1e293b);
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;
}
.container{
    max-width:500px;
}
h1{
    font-size:80px;
    color:#38bdf8;
}
p{
    margin:20px 0;
    opacity:0.8;
}
a{
    display:inline-block;
    margin-top:20px;
    padding:12px 25px;
    background:#38bdf8;
    color:#0f172a;
    text-decoration:none;
    border-radius:30px;
    font-weight:bold;
    transition:0.3s;
}
a:hover{
    background:white;
}
</style>
</head>

<body>
<div class="container">
    <h1>404</h1>
    <p>Oops! The page you're looking for doesn't exist.</p>
    <a href="https://optimalyoungforever-art.github.io/rick/">
        Go Back Home
    </a>
</div>
</body>
</html>
