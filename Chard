<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RichardWeb.com | Official Portfolio</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI', sans-serif;
}

html{
    scroll-behavior:smooth;
}

body{
    background:#f5f7fa;
    color:#333;
}

/* NAVIGATION */
nav{
    background:#0f172a;
    padding:18px 60px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    position:fixed;
    width:100%;
    top:0;
    z-index:1000;
}

nav h2{
    color:#fff;
    letter-spacing:1px;
}

nav ul{
    list-style:none;
    display:flex;
    gap:25px;
}

nav ul li a{
    color:#fff;
    text-decoration:none;
    font-size:15px;
    transition:0.3s;
}

nav ul li a:hover{
    color:#38bdf8;
}

/* HERO SECTION */
.hero{
    height:100vh;
    background:linear-gradient(135deg,#0f172a,#1e293b);
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
    color:white;
}

.hero-content img{
    width:190px;
    height:190px;
    border-radius:50%;
    object-fit:cover;
    border:5px solid #38bdf8;
    margin-bottom:25px;
}

.hero h1{
    font-size:42px;
}

.hero p{
    margin-top:12px;
    font-size:18px;
    opacity:0.9;
}

.btn{
    margin-top:25px;
    padding:12px 28px;
    background:#38bdf8;
    color:#0f172a;
    border:none;
    border-radius:30px;
    cursor:pointer;
    transition:0.3s;
    text-decoration:none;
    font-weight:bold;
    display:inline-block;
}

.btn:hover{
    background:white;
}

/* SECTIONS */
section{
    padding:100px 40px;
    max-width:1000px;
    margin:auto;
}

section h2{
    text-align:center;
    margin-bottom:40px;
    font-size:30px;
    color:#0f172a;
}

/* ABOUT */
.about p{
    text-align:center;
    max-width:700px;
    margin:auto;
    line-height:1.7;
}

/* SKILLS */
.skills-container{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:20px;
}

.skill{
    background:white;
    padding:20px 35px;
    border-radius:12px;
    box-shadow:0 10px 25px rgba(0,0,0,0.08);
    font-weight:500;
}

/* CONTACT */
.contact{
    text-align:center;
}

.contact p{
    margin:10px 0;
}

footer{
    background:#0f172a;
    color:white;
    text-align:center;
    padding:25px;
}
</style>
</head>

<body>

<!-- NAVIGATION -->
<nav>
    <h2>RichardWeb</h2>
    <ul>
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>
</nav>

<!-- HERO -->
<div class="hero">
    <div class="hero-content">
        <img src="profile.jpg" alt="Richard">
        <h1>Hi, I'm Richard 👋</h1>
        <p>Founder of RichardWeb.com | Web Developer & Creative Thinker</p>
        <a href="#contact" class="btn">Work With Me</a>
    </div>
</div>

<!-- ABOUT -->
<section id="about" class="about">
    <h2>About Me</h2>
    <p>
        Welcome to RichardWeb.com. I specialize in building modern, 
        responsive, and professional websites. I am passionate about 
        clean design, smooth user experience, and solving real-world 
        problems through technology.
    </p>
</section>

<!-- SKILLS -->
<section id="skills">
    <h2>Skills & Expertise</h2>
    <div class="skills-container">
        <div class="skill">HTML5</div>
        <div class="skill">CSS3</div>
        <div class="skill">JavaScript</div>
        <div class="skill">Responsive Design</div>
        <div class="skill">UI/UX Design</div>
        <div class="skill">Website Optimization</div>
    </div>
</section>

<!-- CONTACT -->
<section id="contact" class="contact">
    <h2>Contact</h2>
    <p>Email: <strong>optimalyoungforever@gmail.com</strong></p>
    <p>Available for freelance projects and collaborations worldwide.</p>
</section>

<footer>
    © 2026 RichardWeb.com | All Rights Reserved
</footer>

</body>
</html>
